{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "cat >> \"${CLAUDE_PLUGIN_DATA:-$HOME/.promptup}/tool-events.jsonl\"",
          "async": true
        }]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "cat > \"${CLAUDE_PLUGIN_DATA:-$HOME/.promptup}/session-end.json\"",
          "async": true
        }]
      }
    ]
  }
}
